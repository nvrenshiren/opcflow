{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": ["core/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "server/**/*.ts", "web/src/**/*.ts", "web/src/**/*.tsx", "cli.ts", "cli-runner.ts"]
}
